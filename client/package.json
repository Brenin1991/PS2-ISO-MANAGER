{
  "name": "osdxmb-desktop",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"node scripts/wait-and-electron.cjs\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/wait-and-electron.cjs",
    "dev:electron:only": "cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "vite build",
    "preview": "vite preview",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.osdxmb.desktop",
    "productName": "OSDXMB Control",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "extraResources": [
      {
        "from": "../server",
        "to": "osdxmb/server",
        "filter": ["**/*", "!**/.venv/**", "!**/__pycache__/**", "!**/*.pyc"]
      },
      {
        "from": "../OSDXMB",
        "to": "osdxmb/OSDXMB"
      }
    ],
    "win": { "target": "nsis" }
  }
}
